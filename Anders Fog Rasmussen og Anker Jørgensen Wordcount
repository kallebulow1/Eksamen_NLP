# ---- Top 5 ord uden stopord ----

top5_anker <- Anker %>%
  unnest_tokens(word, transcription) %>% # splitter alle ord om til vektorer
  filter(!is.na(word)) %>% # Fjerne alle NA
  filter(str_length(word) > 2) %>% # Fjerne alle små ord "i, at, må"
  anti_join(danske_stopord, by = "word") %>% # Fjern alle ord, som findes i danske_stopord.
  filter(word != "nbsp") %>% # Fjerner nbsp som betyder non-breaking space = et mellemrum, som ikke må brydes.
  count(word, sort = TRUE) %>% # Tæl hvor mange gange hvert ord findes, og sortér med det mest brugte ord øverst.
  slice_head(n = 5) # find top 5 ord 

