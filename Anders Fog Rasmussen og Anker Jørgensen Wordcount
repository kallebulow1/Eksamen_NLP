# ---- API grund-url ----

base_url <- "https://www.dansketaler.dk/api/v1/speeches"

# ---- Funktion: hent én side ----

# ---- Funktion: hent én side ----

hent_side <- function(side_nr) {                         # Laver en funktion, hvor side_nr er sidenummeret vi vil hente
  svar <- GET(                                           # Sender et GET-kald til API'et
    url = base_url,                                      # Bruger den API-url, gemt i base_url
    query = list(                                        # Her angiver vi de ting, API'et skal søge efter
      q = "nytårstale",                                 # Søger efter ordet "nytårstale"
      fields = "title,circumstances,tags,transcription", # Vælger hvilke felter vi vil hente
      per_page = 50,                                     # Henter 50 resultater pr. side
      page = side_nr,                                    # Henter den side, som funktionen får som input
      sort = "date",                                    # Sorterer efter dato
      mode = "plain"                                    # Henter teksten som ren tekst
    )
  )
  stop_for_status(svar)                                  # Stopper koden, hvis API-kaldet fejler
  tekst <- content(svar, as = "text", encoding = "UTF-8") # Laver API-svaret om til tekst med danske tegn
  data <- fromJSON(tekst, flatten = TRUE)                # Laver JSON-tekst om til R-data
  return(data)                                           # Sender data tilbage fra funktionen
}

# ---- Test side 1 ----

side1 <- hent_side(1)        # Henter side 1 fra API'et og gemmer den i objektet side1
side1$meta                   # Viser metadata for side 1, fx antal sider og antal resultater


# ---- Find antal sider ----

antal_sider <- side1$meta$total_pages   # Finder hvor mange sider der findes i alt i API-resultatet
antal_sider                            # Viser antal sider i konsollen

# ---- Hent alle sider ----

alle_sider <- map(1:antal_sider, hent_side)   # Kører funktionen hent_side på alle sider fra 1 til antal_sider

# ---- Saml alle taler ----

nytårstaler_raw <- map_dfr(alle_sider, function(x) {   # Går igennem hver side i alle_sider og samler dem til én dataframe
  as_tibble(x$speeches)                                # Tager speeches-delen fra hver side og laver den om til en tibble
})                                                     # Afslutter funktionen inde i map_dfr

# ---- Se data ----

glimpse(nytårstaler_raw)

# ---- Rens data ----

nytårstaler <- nytårstaler_raw %>%
  mutate(
    year = date.year,
    date = date.iso_date,
    title = str_squish(title),
    transcription = str_squish(transcription)
  ) %>%
  select(
    id,
    title,
    date,
    year,
    url,
    language,
    location,
    circumstances,
    transcription
  )

