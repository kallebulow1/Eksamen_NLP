## Cluster

# går fra fx 12.000 features  2

# PCA reducerer mange pixel-features til få dimensioner
pca <- prcomp(X, center = TRUE, scale. = TRUE)

# tager kun de 2 første komponenter (så vi kan plotte)
X_pca <- pca$x[, 1:2]

# K means

set.seed(123)  # så du får samme resultat hver gang

# modellen finde 2 grupper (fordi vi har 2 klasser)
kmeans_result <- kmeans(X_pca, centers = 2)

# plot

plot(X_pca,
     col = kmeans_result$cluster,
     pch = 19,
     main = "K-means clustering af billeder")

y <- all_labels

table(kmeans_result$cluster, y)

