## Labels = 1 Lego 

lego_labels <- rep(1, length(lego_files))
no_lego_labels <- rep(0, length(no_lego_files))

# Samler data (X billeder, y labels)

all_files <- c(lego_files, no_lego_files)
all_labels <- c(lego_labels, no_lego_labels)


# resize

library(jpeg)
library(imager)

process_image <- function(path) {
  img <- load.image(path)
  img <- resize(img, 64, 64)
  
  # konverter til array
  img_array <- as.array(img)
  
  # flatten (gør til vektor)
  img_vector <- as.vector(img_array)
  
  return(img_vector)
}

## Anvend på billederne

X <- lapply(all_files, process_image)
X <- do.call(rbind, X) # X lavet om til matrix

## Rækker = billeder
## Kolonner = pixel værdier

## kigger på et billed statitsitk

img <- process_image(all_files[1])

summary(img)

## sammenlign lego vs no_lego

lego_sample <- process_image(lego_files[1])
no_lego_sample <- process_image(no_lego_files[1])

mean(lego_sample)
mean(no_lego_sample)

## Fordeling

hist(lego_sample, main="Lego pixel values")
hist(no_lego_sample, main="No Lego pixel values")

## Gennemsnit for alle billeder

lego_means <- sapply(lego_files, function(x) mean(process_image(x)))
no_lego_means <- sapply(no_lego_files, function(x) mean(process_image(x)))

mean(lego_means)
mean(no_lego_means)

