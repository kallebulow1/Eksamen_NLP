# hent meta data i json (kan kun hentes i json) for at se hvor mange sider der 
# indenholder ordet "nytår" i titlen

# Request til API
response <- request(
  "https://www.dansketaler.dk/api/v1/speeches"
) %>%
  req_url_query(
    q = "nytår",
    fields = "title",
    per_page = 50,
    page = 1
  ) %>%
  req_perform()

# Konverter til liste
data <- resp_body_json(response)

# Se metadata
data$meta

# Der er 6 sider der indenholder året nytår
# derfor laver vi et for loop der henter data ned fra alle 6 sider

# Tom liste til data
all_pages <- list()

# Hent alle 6 sider
for(i in 1:6){
  
  url <- paste0(
    "https://www.dansketaler.dk/api/v1/speeches?",
    "q=nytår",
    "&fields=title",
    "&format=csv",
    "&per_page=50",
    "&page=", i
  )
  
  all_pages[[i]] <- read_csv(
    url,
    comment = "#",
    col_types = cols(.default = col_character()),
    show_col_types = FALSE
  )
}

# Saml alle sider
taler_df <- bind_rows(all_pages)

# Filtrer kun statsminister taler
statsminster <- taler_df %>%
  filter(str_detect(
    str_to_lower(`Speakers title`),
    "statsminister"
  ))

# fitlrer så kun Anker Jørgensens taler
anker_speech <- statsminster %>%
  filter(str_detect(Title, "Anker"))



