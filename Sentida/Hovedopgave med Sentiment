# ---- Tæl ord pr dokument ----

word_count <- words_clean %>%
  count(page, word, sort = TRUE)


# ---- Lav document-term matrix ----
names(word_count)
dtm <- word_count %>%
  cast_dtm(page, word, n)


# ---- Kør LDA model ----
# k = antal topics/emner

lda_model <- LDA(
  dtm,
  k = 2,
  control = list(seed = 1234)
)


# ---- Find de vigtigste ord i hvert topic ----

topics_words <- tidy(lda_model, matrix = "beta")


top_words <- topics_words %>%
  group_by(topic) %>%
  slice_max(beta, n = 10) %>%
  ungroup() %>%
  arrange(topic, desc(beta))


# ---- Plot topics ----
names(top_words)
ggplot(top_words, aes(x = reorder(term, beta), y = beta, fill = factor(topic))) +
  geom_col(show.legend = FALSE) +
  coord_flip() +
  facet_wrap(~ topic, scales = "free") +
  labs(
    title = "Topord i hvert topic",
    x = "Ord",
    y = "Beta"
  )




# ---- Pakker ----

library(pdftools)
library(dplyr)
library(tidytext)
library(stringr)
library(topicmodels)
library(ggplot2)
library(tidyr)


# ---- Indlæs PDF ----

text <- pdf_text("Hovedopgave V.1 ændret.pdf")


# ---- Lav tekst til dataframe ----

text_df <- data.frame(
  document = paste0("side_", 1:length(text)),
  text = text,
  stringsAsFactors = FALSE
)


# ---- Rens tekst ----

text_df$text <- tolower(text_df$text)

text_df$text <- str_replace_all(text_df$text, "[0-9]", " ")

text_df$text <- str_replace_all(text_df$text, "[[:punct:]]", " ")

text_df$text <- str_replace_all(text_df$text, "\\s+", " ")


# ---- Lav ord-data ----

words_df <- text_df %>%
  unnest_tokens(word, text)


# ---- Fjern danske stopord ----

stopord <- data.frame(
  word = c(
    "og", "i", "jeg", "det", "at", "en", "den", "til", "er", "som",
    "på", "de", "med", "han", "af", "for", "ikke", "der", "var",
    "mig", "sig", "men", "et", "har", "om", "vi", "min", "havde",
    "ham", "hun", "nu", "over", "da", "fra", "du", "ud", "sin",
    "dem", "os", "op", "man", "hans", "hvor", "eller", "hvad",
    "skal", "selv", "her", "alle", "vil", "blev", "kunne", "ind"
  )
)

words_clean <- words_df %>%
  anti_join(stopord, by = "word") %>%
  filter(str_length(word) > 2)


# ---- Visualisering: top 20 ord ----

top20 <- word_count %>%
