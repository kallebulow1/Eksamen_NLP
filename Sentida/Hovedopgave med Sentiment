# ---- Pakker ----

library(wordcloud)
library(RColorBrewer)
library(readr)

# ---- Lav dansk sentiment ----
# polarity > 0 = positiv
# polarity < 0 = negativ

url <- "https://raw.githubusercontent.com/dsldk/danish-sentiment-lexicon/main/2_headword_headword_polarity.csv"

danish_sentiment <- read_csv(
  url,
  col_names = c(
    "word",
    "homograph",
    "word_class",
    "ddo_id",
    "polarity",
    "word_forms"
  ),
  show_col_types = FALSE,
  locale = locale(encoding = "UTF-8")
)

danish_sentiment <- danish_sentiment %>%
  mutate(sentiment = if_else(polarity > 0, "positive", "negative"))

danish_sentiment_unique <- danish_sentiment %>%
  group_by(word) %>%
  summarise(
    polarity = mean(polarity, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    sentiment = if_else(polarity > 0, "positive", "negative")
  )


# ---- Join ord med sentiment ----
# Her kobler vi dine ord sammen med sentiment-ordbogen

sentiment_words <- words_clean %>%
  inner_join(danish_sentiment, by = "word")


# ---- Optæl ord efter sentiment ----

sentiment_count <- sentiment_words %>%
  count(word, sentiment, sort = TRUE)


# ---- Lav bred dataframe ----
# comparison.cloud skal bruge én kolonne for positiv og én for negativ

sentiment_wide <- sentiment_count %>%
  pivot_wider(
    names_from = sentiment,
    values_from = n,
    values_fill = 0
  )


# ---- Lav matrix til comparison.cloud ----

sentiment_matrix <- sentiment_wide %>%
  select(positive, negative) %>%
  as.matrix()

rownames(sentiment_matrix) <- sentiment_wide$word


# ---- Lav comparison cloud ----

comparison.cloud(
  sentiment_matrix,
  colors = c("gray20", "red"),
  max.words = 100,
  random.order = FALSE
)

# ---- Lav word count ----

# Hvert ord tæller
word_count <- words_clean %>%
  count(word, sort = TRUE)

# ---- Lav total antal ord ----
total_words <- word_count %>%
  summarise(
    total = sum(n)
  )

# ---- Lav freq_by_rank ----

# n = antal gange ordet bruges

# total = samlet antal ord

# rank = ordets placering

# term_frequency = ordets andel af alle ord

freq_by_rank <- word_count %>%
  mutate(
    total = sum(n),
    rank = row_number(),
    term_frequency = n / total
  )

# ---- Se resultatet ----
head(freq_by_rank, 20)

# ---- Plot rank mod term frequency ----

ggplot(freq_by_rank, aes(x = rank, y = term_frequency)) +
  geom_line() +
  scale_x_log10() +
  scale_y_log10() +
  labs(
    title = "Ord-frekvens efter rank",
    x = "Rank",
    y = "Term frequency"
  )

# ---- Vælg midterområdet ----
# Vi fjerner de allermest brugte og de allermindst brugte ord

rank_subset <- freq_by_rank %>%
  filter(rank < 500) %>%
  filter(rank > 10)


# ---- Lineær model ----

zipf_model <- lm(
  log10(term_frequency) ~ log10(rank),
  data = rank_subset
)
zipf_model

# ---- Plot med lineær sammenhæng ----

ggplot(freq_by_rank, aes(x = rank, y = term_frequency)) +
  geom_line() +
  geom_smooth(
    data = rank_subset,
    method = "lm",
    se = FALSE
  ) +
  scale_x_log10() +
  scale_y_log10() +
  labs(
    title = "Zipfs lov: ord-frekvens og rank",
    x = "Rank",
    y = "Term frequency"
  )


# ---- Se modelresultat ----

summary(zipf_model)

