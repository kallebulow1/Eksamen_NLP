    "Jeg elsker kvaliteten og vil købe igen.",
    "Det virker ikke og jeg er skuffet."
  )
)


# ---- Sentiment score ----

anmeldelser$sentiment <- sentida(anmeldelser$tekst)


# ---- Kategori ----

anmeldelser$kategori <- ifelse(
  anmeldelser$sentiment > 0,
  "positiv",
  ifelse(
    anmeldelser$sentiment < 0,
    "negativ",
    "neutral"
  )
)


# ---- Resultat ----

