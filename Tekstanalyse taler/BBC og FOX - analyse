# ============================================================
# TF-IDF SAMMENLIGNING MELLEM FOX OG BBC
# ============================================================

# ---- Saml FOX og BBC som to dokumenter ----

text_df_all <- data.frame(
  document = c("FOX", "BBC"),
  text = c(
    paste(text_fox, collapse = " "),
    paste(text_bbc, collapse = " ")
  ),
  stringsAsFactors = FALSE
)


# ---- Lav tidy text samlet ----

words_all <- text_df_all %>%
  unnest_tokens(word, text)


# ---- Rens samlet tekst ----

words_clean_all <- words_all %>%
  anti_join(stop_words, by = "word") %>%
  anti_join(extra_stopwords, by = "word") %>%
  mutate(
    word = ifelse(word == "fertiliser", "fertilizer", word)
  ) %>%
  filter(!str_detect(word, "^[0-9]+$")) %>%
  filter(!str_detect(word, "^[0-9]+p$")) %>%
  filter(str_length(word) > 2)


# ---- Tæl ord pr artikel ----

word_count_all <- words_clean_all %>%
  count(document, word, sort = TRUE)


# ---- Beregn TF-IDF ----

tfidf_words <- word_count_all %>%
  bind_tf_idf(word, document, n)


# ---- Top TF-IDF ord ----

top_tfidf <- tfidf_words %>%
  group_by(document) %>%
  slice_max(tf_idf, n = 15) %>%
  ungroup()


# ---- Plot TF-IDF ----

top_tfidf %>%
  mutate(word = reorder_within(word, tf_idf, document)) %>%
  ggplot(aes(tf_idf, word, fill = document)) +
  geom_col(show.legend = FALSE) +
  facet_wrap(~ document, scales = "free") +
  scale_y_reordered() +
  labs(
    title = "Ord der er mest karakteristiske for FOX og BBC",
    x = "TF-IDF",
    y = "Ord"
  )



